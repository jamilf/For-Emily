{
  // Static-assets-only Worker. The app is a prebuilt Vite SPA, so wrangler just
  // uploads ./dist — no Worker script and no @cloudflare/vite-plugin (which would
  // require Vite >= 6). The Cloudflare pipeline runs `npm run build` before deploy.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "for-emily",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
