# Emily's Study Sanctuary — environment variables (all optional)
#
# Copy to `.env.local` (gitignored) and fill in as needed. The app runs with
# zero configuration; these only override built-in safe defaults.

# ── Deploy base path ─────────────────────────────────────────────────────────
# Root by default (Cloudflare / local dev). The GitHub Pages workflow sets this
# to the repo subpath so assets resolve under /For-Emily/.
# DEPLOY_BASE=/For-Emily/

# ── Cloud sync (Supabase) ────────────────────────────────────────────────────
# The publishable anon key is safe to ship (Row Level Security is the real
# firewall). Committed fallbacks exist, so these are only for your own project.
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Scripture translation ────────────────────────────────────────────────────
# Default is the public-domain World English Bible (no key required).
# To use a licensed translation such as NIV, set the code AND supply an API.Bible
# key; without a key the app stays on WEB. Never commit a real key.
#   VITE_BIBLE_TRANSLATION=niv
#   VITE_BIBLE_API_KEY=your-api-bible-key
#   VITE_BIBLE_ID=71c6eab17ae5b667-01   # API.Bible bible id for the translation
